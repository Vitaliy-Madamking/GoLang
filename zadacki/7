package main

import "fmt"

func Contains(sl []int, x int) bool {
	for _, value := range sl {
		if value == x {
			return true
		}
	}
	return false
}

func main() {
	numbers := []int{1, 2, 3, 4, 5, 7}

	fmt.Println(Contains(numbers, 3))
	fmt.Println(Contains(numbers, 7))
	fmt.Println(Contains([]int{}, 1))
}
